import os
import requests

def fetch_links():
    # GitHub Secrets থেকে লিঙ্কগুলো পড়া
    sources_raw = os.getenv("SOURCES", "")
    if not sources_raw:
        print("Error: No sources found in GitHub Secrets!")
        return
    
    # লিঙ্কগুলোকে লিস্টে রূপান্তর (কমা দিয়ে আলাদা করা)
    SOURCES = [url.strip() for url in sources_raw.split(",")]
    
    combined_content = "#EXTM3U\n"
    print(f"Total Sources Found: {len(SOURCES)}")

    for url in SOURCES:
        if not url: continue
        try:
            # সোর্স থেকে ডাটা নিয়ে আসা
            response = requests.get(url, timeout=15)
            if response.status_code == 200:
                lines = response.text.splitlines()
                for i in range(len(lines)):
                    line = lines[i].strip()
                    
                    # যদি লাইনে চ্যানেল ইনফো থাকে
                    if line.startswith("#EXTINF"):
                        # পরের লাইনে কি লিঙ্ক আছে তা চেক করা
                        next_line = lines[i+1].strip() if i+1 < len(lines) else ""
                        
                        # .m3u8 বা .mp4 বা যেকোনো সরাসরি ভিডিও লিঙ্ক থাকলে যোগ করবে
                        if "http" in next_line:
                            combined_content += f"{line}\n{next_line}\n"
                print(f"Success: Processed {url[:15]}...")
        except Exception as e:
            print(f"Error fetching source: {e}")

    # ফাইনাল প্লেলিস্ট ফাইল তৈরি
    with open("combined_playlist.m3u", "w", encoding="utf-8") as f:
        f.write(combined_content)
    print("Task Completed: combined_playlist.m3u has been updated.")

if __name__ == "__main__":
    fetch_links()
